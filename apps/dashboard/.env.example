# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real secrets.

# Server-side only (NOT exposed to the browser) — used by BFF API routes
# Points to the backend API — no trailing slash
API_URL=http://localhost:3000

# Must match the API's JWT_SECRET — used to verify session cookies in middleware
JWT_SECRET=change_me_to_match_api_jwt_secret

# Legacy — can be removed once all API calls go through /api/proxy
# (kept for backward compat during transition)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Sentry error tracking (client-side)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/yyyy

# Optional: Sentry source map upload (set in CI/Vercel, not locally)
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=simsim-dashboard
