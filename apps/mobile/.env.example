# Copy this file to .env and fill in values for your environment.
# EXPO_PUBLIC_* variables are inlined at build time by Expo SDK 49+.

# API base URL — no trailing slash
# Local:      EXPO_PUBLIC_API_URL=http://192.168.1.x:3000  (use your LAN IP, not localhost)
# Staging:    EXPO_PUBLIC_API_URL=https://api-staging.simsim.app
# Production: EXPO_PUBLIC_API_URL=https://patient-presence-production-7e3f.up.railway.app
EXPO_PUBLIC_API_URL=https://patient-presence-production-7e3f.up.railway.app
