{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (NestJS)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "api", "dev"],
      "port": 3000
    },
    {
      "name": "Dashboard (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "dashboard", "dev"],
      "port": 3001
    },
    {
      "name": "Mobile (Expo Web)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-C", "apps/mobile", "exec", "expo", "start", "--web", "--port", "8081"],
      "port": 8081
    },
    {
      "name": "Mobile (iOS Simulator)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "mobile", "run", "ios"],
      "port": 8081
    },
    {
      "name": "Scanner (Expo)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-C", "apps/scanner", "exec", "expo", "start", "--port", "8083"],
      "port": 8083
    }
  ]
}
